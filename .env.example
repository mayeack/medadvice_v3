# =============================================================================
# MedAdvice v4 Configuration
# =============================================================================
# This application supports multiple AI providers:
# - Local development: Uses Anthropic API or OpenAI-compatible APIs directly
# - AWS production: Uses Amazon Bedrock
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider Selection
# -----------------------------------------------------------------------------
# Options: "anthropic", "bedrock", or "openai"
AI_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Anthropic API Configuration (used when AI_PROVIDER=anthropic)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# -----------------------------------------------------------------------------
# AWS Bedrock Configuration (used when AI_PROVIDER=bedrock)
# -----------------------------------------------------------------------------
# Note: When running on AWS ECS, credentials come from IAM role (no keys needed)
# For local testing with Bedrock, configure AWS CLI: aws configure
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# -----------------------------------------------------------------------------
# OpenAI-Compatible API Configuration (used when AI_PROVIDER=openai)
# -----------------------------------------------------------------------------
# Works with OpenAI, DeepSeek, Together AI, Ollama, and other compatible APIs.
OPENAI_API_KEY=your_openai_or_compatible_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek example:
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_NAME=MedAdvice v4
APP_VERSION=4.0.0
ENVIRONMENT=development
DEBUG=True

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8001

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Local development: SQLite
DATABASE_URL=sqlite:///./medadvice.db
# AWS production example: PostgreSQL
# DATABASE_URL=postgresql://username:password@rds-endpoint:5432/medadvice

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_TO_FILE=True
LOG_TO_CONSOLE=True
LOG_TO_DATABASE=True
LOG_ROTATION_SIZE=10485760
LOG_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Safety Configuration
# -----------------------------------------------------------------------------
PII_INJECTION_RATE=0.05
REQUIRE_DISCLAIMER_ACCEPTANCE=True
MAX_CLARIFYING_QUESTIONS=3

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_TIMEOUT_MINUTES=30
