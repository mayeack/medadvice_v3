# =============================================================================
# MedAdvice v4 Configuration
# =============================================================================
# This application supports multiple AI providers:
# - Local development: Uses Anthropic API or OpenAI-compatible APIs directly
# - AWS production: Uses Amazon Bedrock
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider Selection
# -----------------------------------------------------------------------------
# Options: "anthropic", "bedrock", or "openai"
AI_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Anthropic API Configuration (used when AI_PROVIDER=anthropic)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# -----------------------------------------------------------------------------
# AWS Bedrock Configuration (used when AI_PROVIDER=bedrock)
# -----------------------------------------------------------------------------
# Note: When running on AWS ECS, credentials come from IAM role (no keys needed)
# For local testing with Bedrock, configure AWS CLI: aws configure
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# -----------------------------------------------------------------------------
# OpenAI-Compatible API Configuration (used when AI_PROVIDER=openai)
# -----------------------------------------------------------------------------
# Works with OpenAI, DeepSeek, Together AI, Ollama, and other compatible APIs.
OPENAI_API_KEY=your_openai_or_compatible_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek example:
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_NAME=MedAdvice v4
APP_VERSION=4.0.0
ENVIRONMENT=development
DEBUG=True

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8001

# Public access gate. When set, every request (except /health) requires this
# value as the HTTP Basic Auth password — one shared secret gates both the web
# UIs and the API. Leave empty/unset to disable (local development).
# Generate one with:  openssl rand -hex 24
# ACCESS_KEY=

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Local development: SQLite
DATABASE_URL=sqlite:///./medadvice.db
# AWS production example: PostgreSQL
# DATABASE_URL=postgresql://username:password@rds-endpoint:5432/medadvice

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_TO_FILE=True
LOG_TO_CONSOLE=True
LOG_TO_DATABASE=True
LOG_ROTATION_SIZE=10485760
LOG_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Safety Configuration
# -----------------------------------------------------------------------------
PII_INJECTION_RATE=0.05
REQUIRE_DISCLAIMER_ACCEPTANCE=True
MAX_CLARIFYING_QUESTIONS=3

# -----------------------------------------------------------------------------
# Cisco AI Defense - Inspection API (optional prompt policy review)
# -----------------------------------------------------------------------------
# When enabled, prompts can be sent to the AI Defense Chat Inspection API for
# runtime policy review (the per-chat "Cisco AI Defense Policy Review" toggle).
# Docs: https://developer.cisco.com/docs/ai-defense-inspection/
#
# Master switch. The UI toggle is ignored unless this is True.
AI_DEFENSE_ENABLED=False
# Inspection API key generated in the AI Defense UI when you create an
# "API" connection (Connect to AI Defense > API connection). Sent in the
# X-Cisco-AI-Defense-API-Key header. Keep this secret; never commit a real key.
AI_DEFENSE_API_KEY=your_ai_defense_inspection_api_key_here
# Regional deployment of your AI Defense tenant: us | eu | ap
AI_DEFENSE_REGION=us
# Optional explicit base URL override (wins over region) for private/hybrid:
# AI_DEFENSE_ENDPOINT=https://us.api.inspect.aidefense.security.cisco.com
# Inspection request timeout (seconds)
AI_DEFENSE_TIMEOUT=10.0
# Behavior when the Inspection API errors/malforms:
#   False = fail closed (block the prompt) - recommended secure default
#   True  = fail open  (allow the prompt through)
AI_DEFENSE_FAIL_OPEN=False
# Comma-separated guardrails enforced explicitly on every Inspection API call
# (sent as config.enabled_rules). Passing rules here applies them directly and
# makes enforcement self-contained/direction-independent instead of relying on
# the SCC-configured policy. Rule names must match the API enum exactly.
# Valid: Code Detection, Harassment, Hate Speech, PCI, PHI, PII,
#        Prompt Injection, Profanity, Sexual Content & Exploitation,
#        Social Division & Polarization, Violence & Public Safety Threats
# Leave empty to fall back to the connection's UI-configured policy (config: {}).
AI_DEFENSE_ENABLED_RULES=PII,PHI,PCI,Harassment,Hate Speech,Profanity,Sexual Content & Exploitation,Violence & Public Safety Threats,Social Division & Polarization,Prompt Injection,Code Detection

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_TIMEOUT_MINUTES=30

# -----------------------------------------------------------------------------
# Agentic Orchestration (LangChain + LangGraph)
# -----------------------------------------------------------------------------
# True  = serve chat turns via the supervisor-routed multi-agent LangGraph
#         workflow (backend/agents). On missing deps / build failure the router
#         transparently falls back to the legacy RecommendationEngine.
# False = always use the legacy engine.
USE_AGENTIC_ENGINE=True
# Name promoted to the OTel GenAI Workflow span (Splunk AI Agent Monitoring
# groups traces by this workflow name).
AGENTIC_WORKFLOW_NAME=medadvice_multi_agent

# -----------------------------------------------------------------------------
# Agentic Observability (OpenTelemetry GenAI -> Splunk Observability Cloud)
# -----------------------------------------------------------------------------
# Master switch for code-based GenAI tracing (Workflow/Agent/LLM spans).
OTEL_ENABLED=False
OTEL_SERVICE_NAME=medadvice-v3
# Export endpoint/headers/protocol use the standard OTEL_* environment variables.
# Example (OTLP gRPC to a local collector):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
